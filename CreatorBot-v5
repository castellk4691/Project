<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cover Creator Studio | Aesthetic Generator</title>
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: rgba(255, 255, 255, 0.05);
            --accent-primary: #8b5cf6;
            --accent-secondary: #ec4899;
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            background-image: radial-gradient(circle at top right, #1e1b4b, #0f172a);
            color: var(--text-main);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 850px;
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        header { text-align: center; margin-bottom: 30px; }
        h1 { font-size: 2.2rem; margin: 0; background: linear-gradient(to right, #a78bfa, #f472b6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        .input-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent-secondary); }
        input, textarea { width: 100%; padding: 14px; background: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; color: white; font-size: 1rem; box-sizing: border-box; }

        button { width: 100%; padding: 16px; background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary)); border: none; border-radius: 12px; color: white; font-weight: bold; font-size: 1.1rem; cursor: pointer; transition: 0.2s; }
        button:hover { transform: scale(1.01); filter: brightness(1.1); }

        #results { display: none; animation: fadeIn 0.5s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .mood-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
        .mood-card { background: rgba(255, 255, 255, 0.03); padding: 20px; border-radius: 16px; }
        
        .palette-label { font-size: 0.75rem; color: var(--text-dim); margin-bottom: 8px; display: block; }
        .palette { display: flex; gap: 6px; margin-bottom: 15px; }
        .swatch { height: 40px; flex-grow: 1; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); }
        
        .copy-box { background: rgba(0, 0, 0, 0.3); padding: 15px; border-radius: 12px; font-size: 0.95rem; line-height: 1.4; white-space: pre-wrap; border-left: 4px solid var(--accent-primary); margin-bottom: 20px; }
        .secondary-btn { background: transparent; border: 1px solid var(--text-dim); margin-top: 10px; }
        
        @media (max-width: 650px) { .mood-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

<div class="container">
    <div id="setup-screen">
        <header>
            <h1>Cover Creator Studio</h1>
            <p style="color: var(--text-dim);">Generate a unique aesthetic for your next TikTok cover.</p>
        </header>

        <div class="input-group">
            <label>Song & Artist</label>
            <input type="text" id="song-info" placeholder="e.g. 'Fast Car' by Luke Combs">
        </div>

        <div class="input-group">
            <label>The Vibe</label>
            <textarea id="vibe-info" rows="2" placeholder="e.g. moody sunset, lo-fi chill, or high energy rock"></textarea>
        </div>

        <button onclick="generatePackage()">Generate My Vibe</button>
    </div>

    <div id="results">
        <div class="mood-grid">
            <div class="mood-card">
                <label>Option 1: Primary Aesthetic</label>
                <span class="palette-label">Visual Palette</span>
                <div class="palette" id="pal-1"></div>
                <p id="vis-1" style="font-size: 0.85rem; color: var(--text-dim);"></p>
            </div>
            <div class="mood-card">
                <label>Option 2: Alternative Mood</label>
                <span class="palette-label">Visual Palette</span>
                <div class="palette" id="pal-2"></div>
                <p id="vis-2" style="font-size: 0.85rem; color: var(--text-dim);"></p>
            </div>
        </div>

        <div class="mood-card" style="margin-top: 0;">
            <label>Typography Suggestion</label>
            <p id="font-suggestion" style="color: var(--accent-primary); font-weight: bold; margin: 5px 0 0 0;"></p>
        </div>

        <label style="margin-top:20px;">Tailored Caption</label>
        <div class="copy-box" id="caption-out"></div>
        
        <label>Smart Hashtags</label>
        <div class="copy-box" id="hashtag-out" style="color: #a78bfa; font-family: monospace;"></div>

        <button class="secondary-btn" onclick="resetApp()">Start Over</button>
    </div>
</div>

<script>
    // Comprehensive Color Pools
    const colorLibrary = {
        emotional: ['#2D3250', '#7077A1', '#F6B17A', '#F1E4C3', '#435585', '#818FB4', '#363062', '#F99417', '#E8C872', '#FFF3CF', '#607274', '#B2A59B', '#D2E0FB', '#8EACCD', '#FEF9E1'],
        dark: ['#000000', '#1A1A1B', '#3D0000', '#820000', '#2C3333', '#2E4F4F', '#040D12', '#183D3D', '#5C8374', '#0F0F0F', '#212121', '#454545', '#191919', '#610C9F', '#940B92'],
        upbeat: ['#FF0075', '#17BEBB', '#D62246', '#4B1D3F', '#FF6B6B', '#4ECDC4', '#FFE66D', '#FF9F1C', '#2EC4B6', '#E71D36', '#011627', '#FDFFFC', '#86A789', '#D2DE32', '#F24C3D'],
        neutral: ['#F8F9F9', '#E5E7E9', '#D7DBDD', '#BDC3C7', '#A6ACAF', '#909497', '#7F8C8D', '#2E4053', '#283747', '#212F3D', '#1B2631']
    };

    const visualLibrary = [
        "Warm candlelight, close-up lens, shallow depth of field, minimalist surroundings.",
        "Grainy film texture, blue hour natural lighting, distant city lights in the background.",
        "Minimalist white room, harsh editorial shadows, clean high-fashion composition.",
        "Dreamy haze, magenta neon backlighting, soft focus transitions between shots.",
        "Nature-inspired, dappled morning sunlight, handheld camera movement for a raw feel.",
        "High contrast black and white, heavy shadow play, silhouette focus."
    ];

    function getRandomColors(type, count) {
        let pool = colorLibrary[type] || colorLibrary.neutral;
        let shuffled = [...pool].sort(() => 0.5 - Math.random());
        return shuffled.slice(0, count);
    }

    function generatePackage() {
        const input = document.getElementById('song-info').value;
        const vibeInput = document.getElementById('vibe-info').value.toLowerCase();
        if (!input || !vibeInput) return alert("Please enter a song and a vibe!");

        // Determine Vibe Group
        let type = 'neutral';
        if (vibeInput.match(/(sad|emo|soft|lo-fi|chill|slow|emotional|heart)/)) type = 'emotional';
        if (vibeInput.match(/(dark|moody|grunge|metal|shadow|night|edgy)/)) type = 'dark';
        if (vibeInput.match(/(upbeat|fun|pop|fast|happy|energy|dance)/)) type = 'upbeat';

        // Extract Content
        let songTitle = input.split(/by/i)[0].trim();
        let artistName = input.toLowerCase().includes('by') ? input.split(/by/i)[1].trim() : "";

        // Render Palettes & Visual Directions
        renderPalette('pal-1', getRandomColors(type, 4));
        renderPalette('pal-2', getRandomColors(type, 4));
        document.getElementById('vis-1').innerText = visualLibrary[Math.floor(Math.random() * visualLibrary.length)];
        document.getElementById('vis-2').innerText = visualLibrary[Math.floor(Math.random() * (visualLibrary.length / 2)) + (visualLibrary.length / 2 - 1)];
        
        // Typography
        const fonts = ["Handwritten & Raw", "Bold Editorial Serif", "Minimalist Sans-Serif", "Vintage Typewriter", "Modern Retro Bubble", "Distorted Gothic"];
        document.getElementById('font-suggestion').innerText = fonts[Math.floor(Math.random() * fonts.length)];

        // Caption (No CTA)
        const caps = [
            `POV: You're listening to a ${vibeInput} version of ${songTitle}.`,
            `Stripping back ${songTitle} and leaning into the ${vibeInput} energy.`,
            `Obsessed with how ${songTitle} sounds when it's this ${vibeInput}.`,
            `The ${vibeInput} take on ${songTitle} that nobody asked for, but I needed to record.`
        ];
        document.getElementById('caption-out').innerText = caps[Math.floor(Math.random() * caps.length)];

        // Hashtags
        const songTag = `#${songTitle.replace(/\s+/g, '')}`;
        const artistTag = artistName ? `#${artistName.replace(/\s+/g, '')}Cover` : "#CoverSong";
        const vibeTag = `#${vibeInput.split(' ')[0]}Aesthetic`;
        const coreTags = ["#TikTokMusic", "#Singer", "#AestheticCover", "#UnsignedArtist"];
        document.getElementById('hashtag-out').innerText = `${songTag} ${artistTag} ${vibeTag} ${coreTags.join(' ')}`;

        document.getElementById('setup-screen').style.display = 'none';
        document.getElementById('results').style.display = 'block';
    }

    function renderPalette(id, colors) {
        const container = document.getElementById(id);
        container.innerHTML = '';
        colors.forEach(c => {
            const s = document.createElement('div');
            s.className = 'swatch';
            s.style.background = c;
            container.appendChild(s);
        });
    }

    function resetApp() {
        document.getElementById('setup-screen').style.display = 'block';
        document.getElementById('results').style.display = 'none';
    }
</script>
</body>
