<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Cover Creator Studio</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>

  <style>
    /* ============================================
       CSS VARIABLES & RESET
    ============================================ */
    :root {
      --bg: #0a0a0a;
      --surface: #111111;
      --surface2: #1a1a1a;
      --border: #2a2a2a;
      --accent: #ff5c35;
      --accent2: #ffb347;
      --text: #f0ede8;
      --text-dim: #888880;
      --font-display: 'Bebas Neue', sans-serif;
      --font-body: 'Share Tech Mono', monospace;
      --glow: 0 0 20px rgba(255, 92, 53, 0.3);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      min-height: 100vh;
      overflow-x: hidden;
      cursor: crosshair;
    }

    /* Grain texture overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 999;
      opacity: 0.4;
    }

    /* Ambient background glow */
    body::after {
      content: '';
      position: fixed;
      top: -20%;
      left: -10%;
      width: 60%;
      height: 60%;
      background: radial-gradient(ellipse, rgba(255,92,53,0.06) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    /* ============================================
       LAYOUT
    ============================================ */
    .wrapper {
      max-width: 780px;
      margin: 0 auto;
      padding: 60px 24px 100px;
      position: relative;
      z-index: 1;
    }

    /* ============================================
       HEADER
    ============================================ */
    header {
      margin-bottom: 60px;
      animation: fadeUp 0.6s ease both;
    }

    .header-eyebrow {
      font-size: 11px;
      letter-spacing: 0.25em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    h1 {
      font-family: var(--font-display);
      font-size: clamp(52px, 10vw, 88px);
      line-height: 0.92;
      letter-spacing: 0.01em;
      color: var(--text);
      margin-bottom: 16px;
    }

    h1 span {
      color: var(--accent);
      display: block;
    }

    .header-sub {
      font-size: 12px;
      color: var(--text-dim);
      line-height: 1.7;
      max-width: 400px;
    }

    /* ============================================
       FORM
    ============================================ */
    .form-section {
      animation: fadeUp 0.6s 0.15s ease both;
    }

    .form-group {
      margin-bottom: 28px;
    }

    label {
      display: block;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 10px;
    }

    input, textarea {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 14px;
      padding: 14px 18px;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      border-radius: 0;
      -webkit-appearance: none;
    }

    input::placeholder, textarea::placeholder {
      color: var(--text-dim);
    }

    input:focus, textarea:focus {
      border-color: var(--accent);
      box-shadow: var(--glow);
    }

    textarea {
      resize: vertical;
      min-height: 90px;
      line-height: 1.6;
    }

    /* Two-col layout for first two inputs */
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    @media (max-width: 520px) {
      .form-row { grid-template-columns: 1fr; }
    }

    /* Generate button */
    .btn-generate {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--accent);
      color: #000;
      font-family: var(--font-display);
      font-size: 22px;
      letter-spacing: 0.08em;
      padding: 16px 36px;
      border: none;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s;
      margin-top: 8px;
    }

    .btn-generate:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(255,92,53,0.4);
    }

    .btn-generate:active { transform: translateY(0); }

    .btn-generate:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    /* ============================================
       LOADING STATE
    ============================================ */
    .loading {
      display: none;
      margin-top: 48px;
      text-align: center;
      animation: fadeUp 0.4s ease both;
    }

    .loading.visible { display: block; }

    .loading-text {
      font-size: 11px;
      letter-spacing: 0.2em;
      color: var(--accent);
      text-transform: uppercase;
      animation: pulse 1.2s ease-in-out infinite;
    }

    .loading-bar {
      width: 200px;
      height: 2px;
      background: var(--border);
      margin: 14px auto 0;
      overflow: hidden;
    }

    .loading-bar::after {
      content: '';
      display: block;
      height: 100%;
      width: 40%;
      background: var(--accent);
      animation: slide 1s ease-in-out infinite;
    }

    /* ============================================
       RESULTS SECTION
    ============================================ */
    #results {
      display: none;
      margin-top: 64px;
      animation: fadeUp 0.5s ease both;
    }

    #results.visible { display: block; }

    .results-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 48px;
    }

    .results-divider span {
      font-family: var(--font-display);
      font-size: 32px;
      color: var(--accent);
      white-space: nowrap;
    }

    .results-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* Result cards */
    .result-card {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 28px;
      margin-bottom: 20px;
      position: relative;
    }

    .result-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px;
      height: 100%;
      background: var(--accent);
    }

    .card-label {
      font-size: 9px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 16px;
    }

    /* Color palette swatches */
    .palette-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .swatch {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      cursor: pointer;
    }

    .swatch-color {
      width: 52px;
      height: 52px;
      border: 1px solid rgba(255,255,255,0.08);
      transition: transform 0.15s, box-shadow 0.15s;
    }

    .swatch:hover .swatch-color {
      transform: scale(1.08);
    }

    .swatch-hex {
      font-size: 9px;
      color: var(--text-dim);
      letter-spacing: 0.05em;
    }

    .swatch.copied .swatch-hex { color: var(--accent); }

    /* Text content in results */
    .result-text {
      font-size: 13px;
      line-height: 1.8;
      color: var(--text);
    }

    .result-text strong {
      color: var(--accent2);
      font-weight: normal;
    }

    /* Hashtags */
    .hashtag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }

    .hashtag {
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 5px 12px;
      font-size: 11px;
      color: var(--accent);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }

    .hashtag:hover {
      background: var(--accent);
      color: #000;
      border-color: var(--accent);
    }

    /* Copy buttons */
    .copy-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: none;
      border: 1px solid var(--border);
      color: var(--text-dim);
      font-family: var(--font-body);
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 7px 14px;
      cursor: pointer;
      margin-top: 14px;
      transition: all 0.15s;
    }

    .copy-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .copy-btn.copied {
      border-color: #4caf50;
      color: #4caf50;
    }

    /* Start over button */
    .btn-reset {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: none;
      border: 1px solid var(--border);
      color: var(--text-dim);
      font-family: var(--font-display);
      font-size: 20px;
      letter-spacing: 0.08em;
      padding: 14px 28px;
      cursor: pointer;
      margin-top: 40px;
      transition: all 0.2s;
    }

    .btn-reset:hover {
      border-color: var(--text);
      color: var(--text);
    }

    /* Error state */
    .error-msg {
      display: none;
      margin-top: 20px;
      padding: 14px 18px;
      border: 1px solid #ff3b3b;
      background: rgba(255,59,59,0.05);
      font-size: 12px;
      color: #ff6b6b;
      line-height: 1.6;
    }

    .error-msg.visible { display: block; }

    /* ============================================
       ANIMATIONS
    ============================================ */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.4; }
    }

    @keyframes slide {
      0%   { transform: translateX(-100%); }
      100% { transform: translateX(350%); }
    }

    /* Footer */
    footer {
      margin-top: 80px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
      font-size: 10px;
      color: var(--text-dim);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      animation: fadeUp 0.6s 0.3s ease both;
    }
  </style>
</head>
<body>

<div class="wrapper">

  <!-- ============================================
       HEADER
  ============================================ -->
  <header>
    <p class="header-eyebrow">↯ AI-Powered TikTok Tool</p>
    <h1>COVER<span>CREATOR</span></h1>
    <p class="header-sub">
      Drop your song info and vibe. Get back a full TikTok creative package — 
      palette, aesthetic direction, caption, and hashtags. Ready to post.
    </p>
  </header>

  <!-- ============================================
       INPUT FORM
  ============================================ -->
  <section class="form-section">
    <div class="form-row">
      <div class="form-group">
        <label for="song-title">Song Title</label>
        <input type="text" id="song-title" placeholder="e.g. Grenade" />
      </div>
      <div class="form-group">
        <label for="original-artist">Original Artist</label>
        <input type="text" id="original-artist" placeholder="e.g. Bruno Mars" />
      </div>
    </div>

    <div class="form-group">
      <label for="vibe">Your Spin / Mood</label>
      <textarea id="vibe" placeholder="e.g. soft and emotional, stripped back acoustic — I want it to feel vulnerable and late-night"></textarea>
    </div>

    <button class="btn-generate" id="generate-btn" onclick="generateVibe()">
      ↯ Generate My Vibe
    </button>

    <!-- Error message -->
    <div class="error-msg" id="error-msg"></div>
  </section>

  <!-- Loading indicator -->
  <div class="loading" id="loading">
    <p class="loading-text">Building your aesthetic...</p>
    <div class="loading-bar"></div>
  </div>

  <!-- ============================================
       RESULTS SECTION
  ============================================ -->
  <section id="results">
    <div class="results-divider"><span>YOUR VIBE PACKAGE</span></div>

    <!-- MOOD BOARD CARD -->
    <div class="result-card" id="card-moodboard">
      <p class="card-label">↯ Aesthetic Mood Board</p>

      <div class="palette-row" id="palette-row"></div>

      <div class="result-text" id="vibe-description"></div>

      <div class="result-text" style="margin-top:16px;" id="font-suggestion"></div>
      <div class="result-text" style="margin-top:12px;" id="visual-direction"></div>
    </div>

    <!-- CAPTION CARD -->
    <div class="result-card" id="card-caption">
      <p class="card-label">↯ TikTok Caption</p>
      <div class="result-text" id="caption-text"></div>
      <button class="copy-btn" id="copy-caption-btn" onclick="copyText('caption-text', 'copy-caption-btn')">
        ⊕ Copy Caption
      </button>
    </div>

    <!-- HASHTAGS CARD -->
    <div class="result-card" id="card-hashtags">
      <p class="card-label">↯ Hashtags</p>
      <div class="hashtag-list" id="hashtag-list"></div>
      <button class="copy-btn" id="copy-hashtags-btn" onclick="copyHashtags()">
        ⊕ Copy All Hashtags
      </button>
    </div>

    <!-- CTA CARD -->
    <div class="result-card" id="card-cta">
      <p class="card-label">↯ Anonymous-Friendly CTA</p>
      <div class="result-text" id="cta-text"></div>
      <button class="copy-btn" id="copy-cta-btn" onclick="copyText('cta-text', 'copy-cta-btn')">
        ⊕ Copy CTA
      </button>
    </div>

    <!-- Reset -->
    <button class="btn-reset" onclick="resetApp()">← Start Over</button>
  </section>

  <footer>Cover Creator Studio &nbsp;·&nbsp; MVP v1.0 &nbsp;·&nbsp; Powered by Claude AI</footer>

</div><!-- /wrapper -->

<!-- ============================================
     JAVASCRIPT
============================================ -->
<script>
  // ── State ──────────────────────────────────────
  let currentHashtags = [];

  // ── Main generation function ───────────────────
  async function generateVibe() {
    const song   = document.getElementById('song-title').value.trim();
    const artist = document.getElementById('original-artist').value.trim();
    const vibe   = document.getElementById('vibe').value.trim();
    const errEl  = document.getElementById('error-msg');

    // Basic validation
    if (!song || !artist || !vibe) {
      showError('Please fill in all three fields before generating.');
      return;
    }

    // UI: loading state
    errEl.classList.remove('visible');
    document.getElementById('generate-btn').disabled = true;
    document.getElementById('loading').classList.add('visible');
    document.getElementById('results').classList.remove('visible');

    // Build the prompt for Claude
    const prompt = `
You are Cover Creator Studio, an AI tool that helps TikTok cover song creators build cohesive aesthetic packages for their posts.

A user wants to post a cover of "${song}" by ${artist}. Their intended mood/vibe is: "${vibe}"

Return ONLY a valid JSON object (no markdown, no explanation, no extra text) in this exact structure:

{
  "palette": [
    {"hex": "#XXXXXX", "name": "short name"},
    {"hex": "#XXXXXX", "name": "short name"},
    {"hex": "#XXXXXX", "name": "short name"},
    {"hex": "#XXXXXX", "name": "short name"}
  ],
  "vibeDescription": "2-3 sentences describing the visual mood that matches the song and their spin on it.",
  "fontSuggestion": "Describe 1-2 font style recommendations with brief context (e.g. 'A delicate serif like Cormorant for titles — something that feels fragile and honest.').",
  "visualDirection": "One practical visual direction tip for filming/editing the TikTok (e.g. 'Think: close-up of hands on guitar, soft window light, minimal cuts.').",
  "caption": "A punchy, emotionally resonant TikTok caption. 1-3 lines max. No hashtags. Should feel authentic, not corporate.",
  "hashtags": ["#hashtag1", "#hashtag2", "#hashtag3", "#hashtag4", "#hashtag5", "#hashtag6", "#hashtag7", "#hashtag8", "#hashtag9", "#hashtag10", "#hashtag11", "#hashtag12"],
  "cta": "A short anonymous-friendly call to action to add after the caption (e.g. 'drop your favorite lyric below 👇')."
}

Make the palette deeply evocative of the mood — not generic. Mix tones intentionally.
Hashtags should include a mix of niche music/cover tags AND broader TikTok reach tags.
`;

    try {
      // Call the Anthropic API
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{ role: "user", content: prompt }]
        })
      });

      if (!response.ok) throw new Error(`API error: ${response.status}`);

      const data = await response.json();

      // Extract text content from response
      const rawText = data.content
        .filter(b => b.type === "text")
        .map(b => b.text)
        .join("");

      // Strip any accidental markdown fences
      const clean = rawText.replace(/```json|```/gi, "").trim();
      const result = JSON.parse(clean);

      // Render the results
      renderResults(result);

    } catch (err) {
      console.error(err);
      showError('Something went wrong generating your vibe. Check your connection and try again.');
    } finally {
      document.getElementById('generate-btn').disabled = false;
      document.getElementById('loading').classList.remove('visible');
    }
  }

  // ── Render results into the DOM ────────────────
  function renderResults(data) {
    // — Color Palette —
    const paletteRow = document.getElementById('palette-row');
    paletteRow.innerHTML = '';
    data.palette.forEach(color => {
      const swatch = document.createElement('div');
      swatch.className = 'swatch';
      swatch.innerHTML = `
        <div class="swatch-color" style="background:${color.hex}; box-shadow: 0 0 16px ${color.hex}55;"></div>
        <span class="swatch-hex">${color.hex}</span>
      `;
      swatch.onclick = () => copySwatch(swatch, color.hex);
      paletteRow.appendChild(swatch);
    });

    // — Vibe description —
    document.getElementById('vibe-description').innerHTML = data.vibeDescription;

    // — Font suggestion —
    document.getElementById('font-suggestion').innerHTML =
      `<strong>Typography →</strong> ${data.fontSuggestion}`;

    // — Visual direction —
    document.getElementById('visual-direction').innerHTML =
      `<strong>Visual direction →</strong> ${data.visualDirection}`;

    // — Caption —
    document.getElementById('caption-text').textContent = data.caption;
    resetCopyBtn('copy-caption-btn', '⊕ Copy Caption');

    // — Hashtags —
    currentHashtags = data.hashtags;
    const hashtagList = document.getElementById('hashtag-list');
    hashtagList.innerHTML = '';
    data.hashtags.forEach(tag => {
      const el = document.createElement('span');
      el.className = 'hashtag';
      el.textContent = tag;
      el.onclick = () => {
        navigator.clipboard.writeText(tag);
        el.style.background = 'var(--accent)';
        el.style.color = '#000';
        setTimeout(() => {
          el.style.background = '';
          el.style.color = '';
        }, 1000);
      };
      hashtagList.appendChild(el);
    });
    resetCopyBtn('copy-hashtags-btn', '⊕ Copy All Hashtags');

    // — CTA —
    document.getElementById('cta-text').textContent = data.cta;
    resetCopyBtn('copy-cta-btn', '⊕ Copy CTA');

    // Show results
    document.getElementById('results').classList.add('visible');
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Copy helpers ───────────────────────────────
  function copyText(elementId, btnId) {
    const text = document.getElementById(elementId).textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById(btnId);
      btn.textContent = '✓ Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.textContent = btnId.includes('caption') ? '⊕ Copy Caption' : '⊕ Copy CTA';
      }, 2000);
    });
  }

  function copyHashtags() {
    const text = currentHashtags.join(' ');
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-hashtags-btn');
      btn.textContent = '✓ Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.textContent = '⊕ Copy All Hashtags';
      }, 2000);
    });
  }

  function copySwatch(swatchEl, hex) {
    navigator.clipboard.writeText(hex).then(() => {
      const hexEl = swatchEl.querySelector('.swatch-hex');
      const orig = hexEl.textContent;
      hexEl.textContent = 'copied!';
      swatchEl.classList.add('copied');
      setTimeout(() => {
        hexEl.textContent = orig;
        swatchEl.classList.remove('copied');
      }, 1500);
    });
  }

  function resetCopyBtn(id, label) {
    const btn = document.getElementById(id);
    btn.textContent = label;
    btn.classList.remove('copied');
  }

  // ── Error display ──────────────────────────────
  function showError(msg) {
    const el = document.getElementById('error-msg');
    el.textContent = msg;
    el.classList.add('visible');
  }

  // ── Reset / Start Over ─────────────────────────
  function resetApp() {
    document.getElementById('song-title').value = '';
    document.getElementById('original-artist').value = '';
    document.getElementById('vibe').value = '';
    document.getElementById('results').classList.remove('visible');
    document.getElementById('error-msg').classList.remove('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    document.getElementById('song-title').focus();
  }

  // ── Allow Enter key in inputs to submit ────────
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA' && !e.shiftKey) {
      generateVibe();
    }
  });
</script>

</body>
</html>
